        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": false
    },
    "slug": {
      "type": "uid"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "text"
    },
    "author": {
      "type": "string"
    },
    "htmlContent": {
      "type": "text"
    },
    "publishDate": {
      "type": "date"
    },
    "tags": {
      "type": "json"
    },
    "description": {
      "type": "text"
    },
    "email": {
      "type": "email"
    }
  }
}
